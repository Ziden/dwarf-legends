@page "/map-preview"
@rendermode InteractiveServer
@using DwarfFortress.WorldGen.Maps
@using DwarfFortress.WorldGen.Ids
@using DwarfFortress.WorldGen.Regions
@using DwarfFortress.WorldGen.World
@inject MapPreviewService MapPreviewSvc

<PageTitle>Map Preview</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <div>
        <h2 class="mb-1">Map Preview</h2>
        <p class="text-muted mb-0">
            Inspect world tile selection, region chunk context, and local map output from one deterministic seed.
        </p>
    </div>
</div>

<div class="card shadow-sm map-preview-panel mb-3">
    <div class="card-body">
        <h6 class="mb-2">Generation Controls</h6>
        <div class="row g-2 align-items-end">
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Seed</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_seed" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Local Width</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_width" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Local Height</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_height" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Local Depth</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_depth" />
            </div>
            <div class="col-md-6 col-lg-4">
                <label class="form-label">Biome Source</label>
                <InputSelect class="form-select form-select-sm" @bind-Value="_selectedBiome">
                    <option value="@BiomeFromGeneratorOption">Region-derived (layered default)</option>
                    <option value="@BiomeFromLoreOption">From lore (game-like)</option>
                    @foreach (var biome in _biomes)
                    {
                        <option value="@biome">@biome</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="row g-2 align-items-end mt-1">
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">World Width</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_worldWidth" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">World Height</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_worldHeight" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Region Width</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_regionWidth" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Region Height</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_regionHeight" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">World X</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_worldX" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">World Y</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_worldY" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Region X</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_regionX" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Region Y</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_regionY" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label">Region Heat</label>
                <InputSelect class="form-select form-select-sm" @bind-Value="_regionHeatMode">
                    <option value="@HeatModeBiome">Biome Variant</option>
                    <option value="@HeatModeVegetation">Vegetation</option>
                    <option value="@HeatModeResources">Resource Richness</option>
                    <option value="@HeatModeSlope">Slope</option>
                    <option value="@HeatModeRivers">River Contract</option>
                </InputSelect>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-3">
            <button class="btn btn-primary btn-sm" @onclick="Generate">Generate</button>
            <button class="btn btn-outline-primary btn-sm" @onclick="Regenerate">Regenerate (next seed)</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="RandomizeAndGenerate">Random seed</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@if (_run is not null && _layerStats is not null)
{
    <div class="row g-3 mb-3">
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">World Tile</div>
                    <div class="fw-semibold">(@_run.Request.WorldX, @_run.Request.WorldY)</div>
                    <div class="small"><code>@_run.SelectedWorldTile.MacroBiomeId</code></div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Region Cell</div>
                    <div class="fw-semibold">(@_run.Request.RegionX, @_run.Request.RegionY)</div>
                    <div class="small"><code>@_run.SelectedRegionTile.BiomeVariantId</code></div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Local Surface</div>
                    <div class="fw-semibold">
                        @_run.LocalStats.TreeTiles trees | @_run.LocalStats.WaterTiles water | @_run.LocalStats.WallTiles walls
                    </div>
                    <div class="small text-muted">biome source: @ResolvedBiomeLabel</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Ore Potential</div>
                    <div class="fw-semibold">@($"{_run.LocalStats.OrePotential * 100f:0.0}%")</div>
                    <div class="small text-muted">@_run.LocalStats.OrePotentialLabel</div>
                </div>
            </div>
        </div>
    </div>

    @if (_run.LocalStats.TreeTiles == 0)
    {
        <div class="alert alert-warning">
            This local map has zero surface trees. Check selected region vegetation, biome variant, and local biome override.
        </div>
    }

    <div class="row g-3 mb-3">
        <div class="col-xl-6">
            <div class="card shadow-sm map-preview-panel h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">World Tile Picker</h6>
                        <span class="small text-muted">click a tile to load its region chunk</span>
                    </div>
                    <div class="map-scroll picker-scroll">
                        <div class="map-grid" style="@GetWorldGridStyle()">
                            @for (var y = 0; y < _run.WorldMap.Height; y++)
                            {
                                for (var x = 0; x < _run.WorldMap.Width; x++)
                                {
                                    var worldX = x;
                                    var worldY = y;
                                    var tile = _run.WorldMap.GetTile(worldX, worldY);
                                    var isSelected = worldX == _run.Request.WorldX && worldY == _run.Request.WorldY;
                                    <button type="button"
                                            class="map-cell @(isSelected ? "map-cell-selected" : "")"
                                            style="@GetWorldTileStyle(tile)"
                                            title="@GetWorldTileTooltip(worldX, worldY, tile)"
                                            @onclick="() => SelectWorldTile(worldX, worldY)">
                                    </button>
                                }
                            }
                        </div>
                    </div>

                    <div class="small text-muted mt-2">
                        avg elevation @_run.WorldStats.AvgElevation.ToString("0.00") | avg moisture @_run.WorldStats.AvgMoisture.ToString("0.00") |
                        avg drainage @_run.WorldStats.AvgDrainage.ToString("0.00")
                    </div>
                    <div class="small text-muted">
                        avg temperature @_run.WorldStats.AvgTemperature.ToString("0.00") | avg faction pressure @_run.WorldStats.AvgFactionPressure.ToString("0.00")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card shadow-sm map-preview-panel h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Region Heatmap</h6>
                        <span class="small text-muted">click a cell to regenerate local map</span>
                    </div>
                    <div class="map-scroll picker-scroll">
                        <div class="map-grid" style="@GetRegionGridStyle()">
                            @for (var y = 0; y < _run.RegionMap.Height; y++)
                            {
                                for (var x = 0; x < _run.RegionMap.Width; x++)
                                {
                                    var regionX = x;
                                    var regionY = y;
                                    var tile = _run.RegionMap.GetTile(regionX, regionY);
                                    var isSelected = regionX == _run.Request.RegionX && regionY == _run.Request.RegionY;
                                    <button type="button"
                                            class="map-cell @(isSelected ? "map-cell-selected" : "")"
                                            style="@GetRegionTileStyle(tile)"
                                            title="@GetRegionTileTooltip(regionX, regionY, tile)"
                                            @onclick="() => SelectRegionTile(regionX, regionY)">
                                    </button>
                                }
                            }
                        </div>
                    </div>

                    <div class="small text-muted mt-2">
                        rivers @_run.RegionStats.RiverTiles | lakes @_run.RegionStats.LakeTiles |
                        roads @_run.RegionStats.RoadTiles | settlements @_run.RegionStats.SettlementTiles
                    </div>
                    <div class="small text-muted">
                        avg vegetation @_run.RegionStats.AvgVegetationDensity.ToString("0.00") |
                        avg resources @_run.RegionStats.AvgResourceRichness.ToString("0.00") |
                        avg slope @_run.RegionStats.AvgSlope.ToString("0.00")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-xl-9">
            <div class="card shadow-sm map-preview-panel">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Local Map Preview</h6>
                        <span class="small text-muted">selected from world (@_run.Request.WorldX,@_run.Request.WorldY) / region (@_run.Request.RegionX,@_run.Request.RegionY)</span>
                    </div>

                    <div class="row g-2 align-items-end mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Layer (z)</label>
                            <input type="range"
                                   class="form-range"
                                   min="0"
                                   max="@(_run.LocalMap.Depth - 1)"
                                   step="1"
                                   value="@_layer"
                                   @oninput="OnLayerChanged" />
                            <div class="small text-muted">z = @_layer / @(_run.LocalMap.Depth - 1)</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Cell Size (px)</label>
                            <input type="range"
                                   class="form-range"
                                   min="8"
                                   max="20"
                                   step="1"
                                   value="@_cellSize"
                                   @oninput="OnCellSizeChanged" />
                            <div class="small text-muted">@_cellSize px</div>
                        </div>
                        <div class="col-md-4 small text-muted">
                            Click any tile for exact coordinates/material and fluid values.
                        </div>
                    </div>

                    <div class="map-scroll">
                        <div class="map-grid" style="@GetLocalGridStyle()">
                            @for (var y = 0; y < _run.LocalMap.Height; y++)
                            {
                                for (var x = 0; x < _run.LocalMap.Width; x++)
                                {
                                    var localX = x;
                                    var localY = y;
                                    var tile = _run.LocalMap.GetTile(localX, localY, _layer);
                                    var isSelected = _selectedTile is not null && _selectedTile.X == localX && _selectedTile.Y == localY && _selectedTile.Z == _layer;
                                    <button type="button"
                                            class="map-cell @(isSelected ? "map-cell-selected" : "")"
                                            style="@GetLocalTileStyle(tile)"
                                            title="@GetLocalTileTooltip(localX, localY, tile)"
                                            @onclick="() => SelectLocalTile(localX, localY)">
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3">
            <div class="card shadow-sm map-preview-panel mb-3">
                <div class="card-body">
                    <h6 class="mb-3">Layer Stats</h6>
                    <div class="small text-muted">z = @_layer</div>
                    <div><strong>@_layerStats.PassableTiles</strong> passable (@FormatRatio(_layerStats.PassableTiles, _layerStats.TotalTiles))</div>
                    <div><strong>@_layerStats.TreeTiles</strong> trees</div>
                    <div><strong>@_layerStats.WaterTiles</strong> water</div>
                    <div><strong>@_layerStats.WallTiles</strong> walls</div>
                    <div><strong>@_layerStats.AquiferTiles</strong> aquifer</div>
                    <div><strong>@_layerStats.OreTiles</strong> ore</div>
                </div>
            </div>

            <div class="card shadow-sm map-preview-panel mb-3">
                <div class="card-body">
                    <h6 class="mb-3">Selected Region Cell</h6>
                    <div><code>@_run.SelectedRegionTile.BiomeVariantId</code></div>
                    <div class="small text-muted">geology: @_run.SelectedRegionTile.GeologyProfileId</div>
                    <div class="small text-muted">river: @_run.SelectedRegionTile.HasRiver | lake: @_run.SelectedRegionTile.HasLake</div>
                    <div class="small text-muted">river edges: @_run.SelectedRegionTile.RiverEdges</div>
                    <div class="small text-muted">road: @_run.SelectedRegionTile.HasRoad | settlement: @_run.SelectedRegionTile.HasSettlement</div>
                    <div class="small text-muted">veg: @_run.SelectedRegionTile.VegetationDensity.ToString("0.00")</div>
                    <div class="small text-muted">resources: @_run.SelectedRegionTile.ResourceRichness.ToString("0.00")</div>
                    <div class="small text-muted">slope: @((_run.SelectedRegionTile.Slope / 255f).ToString("0.00"))</div>
                </div>
            </div>

            <div class="card shadow-sm map-preview-panel mb-3">
                <div class="card-body">
                    <h6 class="mb-3">Selected Tile</h6>
                    @if (_selectedTile is null)
                    {
                        <div class="text-muted small">No local tile selected.</div>
                    }
                    else
                    {
                        <div><strong>(@_selectedTile.X, @_selectedTile.Y, @_selectedTile.Z)</strong></div>
                        <div><code>@_selectedTile.TileDefId</code></div>
                        <div class="small text-muted">material: @(_selectedTile.MaterialId ?? "none")</div>
                        <div class="small text-muted">species: @(_selectedTile.TreeSpeciesId ?? "none")</div>
                        <div class="small text-muted">ore: @(_selectedTile.OreId ?? "none")</div>
                        <div class="small text-muted">aquifer: @_selectedTile.IsAquifer</div>
                        <div class="small text-muted">passable: @_selectedTile.IsPassable</div>
                        <div class="small text-muted">fluid: @_selectedTile.FluidType / level @_selectedTile.FluidLevel</div>
                    }
                </div>
            </div>

            <div class="card shadow-sm map-preview-panel">
                <div class="card-body">
                    <h6 class="mb-3">Tile Breakdown</h6>
                    <div class="tile-breakdown">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Tile</th>
                                    <th class="text-end">Count</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in _layerStats.TileBreakdown)
                                {
                                    <tr>
                                        <td><code>@entry.TileDefId</code></td>
                                        <td class="text-end">@entry.Count</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .map-preview-panel {
        border: 1px solid rgba(15, 23, 42, 0.12);
        border-radius: 1rem;
    }

    .map-scroll {
        max-width: 100%;
        max-height: 70vh;
        overflow: auto;
        padding: 0.5rem;
        border: 1px solid rgba(15, 23, 42, 0.15);
        border-radius: 0.75rem;
        background: #0b1220;
    }

    .picker-scroll {
        max-height: 28rem;
    }

    .map-grid {
        --cell-size: 12px;
        display: grid;
        width: max-content;
        background: #0f172a;
        box-shadow: 0 16px 32px rgba(2, 6, 23, 0.35);
    }

    .map-cell {
        appearance: none;
        width: var(--cell-size);
        height: var(--cell-size);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 0;
        margin: 0;
        cursor: pointer;
    }

    .map-cell:hover {
        outline: 1px solid rgba(248, 250, 252, 0.85);
        position: relative;
        z-index: 1;
    }

    .map-cell-selected {
        outline: 2px solid rgba(255, 255, 255, 0.95);
        position: relative;
        z-index: 2;
    }

    .tile-breakdown {
        max-height: 18rem;
        overflow-y: auto;
    }
</style>

@code {
    private const string BiomeFromLoreOption = "__from_lore__";
    private const string BiomeFromGeneratorOption = "__generator_default__";

    private const string HeatModeBiome = "biome";
    private const string HeatModeVegetation = "vegetation";
    private const string HeatModeResources = "resources";
    private const string HeatModeSlope = "slope";
    private const string HeatModeRivers = "rivers";

    private readonly List<string> _biomes = [];
    private MapPreviewRun? _run;
    private MapLayerStats? _layerStats;
    private SelectedTileInfo? _selectedTile;

    private string _selectedBiome = BiomeFromGeneratorOption;
    private string _regionHeatMode = HeatModeBiome;
    private string _error = "";

    private int _seed = 42;
    private int _width = 48;
    private int _height = 48;
    private int _depth = 8;
    private int _worldWidth = 24;
    private int _worldHeight = 24;
    private int _regionWidth = 16;
    private int _regionHeight = 16;
    private int _worldX = 12;
    private int _worldY = 12;
    private int _regionX = 8;
    private int _regionY = 8;

    private int _layer;
    private int _cellSize = 12;

    protected override void OnInitialized()
    {
        _biomes.AddRange(MapPreviewSvc.ListBiomes().OrderBy(x => x, StringComparer.OrdinalIgnoreCase));
        Generate();
    }

    private void Generate()
    {
        _error = "";

        try
        {
            NormalizeInputs();

            var useLoreBiome = string.Equals(_selectedBiome, BiomeFromLoreOption, StringComparison.Ordinal);
            var biomeId = string.Equals(_selectedBiome, BiomeFromGeneratorOption, StringComparison.Ordinal)
                ? null
                : _selectedBiome;

            var request = new MapPreviewRequest(
                Seed: _seed,
                LocalWidth: _width,
                LocalHeight: _height,
                LocalDepth: _depth,
                WorldWidth: _worldWidth,
                WorldHeight: _worldHeight,
                RegionWidth: _regionWidth,
                RegionHeight: _regionHeight,
                WorldX: _worldX,
                WorldY: _worldY,
                RegionX: _regionX,
                RegionY: _regionY,
                BiomeId: biomeId,
                UseLoreBiome: useLoreBiome);

            _run = MapPreviewSvc.Generate(request);
            ApplyRequest(_run.Request);

            _layer = Math.Clamp(_layer, 0, _run.LocalMap.Depth - 1);
            _selectedTile = null;
            RefreshLayerStats();
        }
        catch (Exception ex)
        {
            _run = null;
            _layerStats = null;
            _selectedTile = null;
            _error = ex.Message;
        }
    }

    private void Regenerate()
    {
        _seed++;
        Generate();
    }

    private void RandomizeAndGenerate()
    {
        _seed = Random.Shared.Next(1, int.MaxValue);
        Generate();
    }

    private void SelectWorldTile(int worldX, int worldY)
    {
        _worldX = worldX;
        _worldY = worldY;
        Generate();
    }

    private void SelectRegionTile(int regionX, int regionY)
    {
        _regionX = regionX;
        _regionY = regionY;
        Generate();
    }

    private void OnLayerChanged(ChangeEventArgs e)
    {
        if (_run is null)
            return;

        if (int.TryParse(e.Value?.ToString(), out var value))
        {
            _layer = Math.Clamp(value, 0, _run.LocalMap.Depth - 1);
            _selectedTile = null;
            RefreshLayerStats();
        }
    }

    private void OnCellSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
            _cellSize = Math.Clamp(value, 8, 20);
    }

    private void RefreshLayerStats()
    {
        if (_run is null)
        {
            _layerStats = null;
            return;
        }

        _layerStats = MapPreviewSvc.AnalyzeLayer(_run.LocalMap, _layer);
    }

    private void SelectLocalTile(int x, int y)
    {
        if (_run is null)
            return;

        var tile = _run.LocalMap.GetTile(x, y, _layer);
        _selectedTile = new SelectedTileInfo(
            X: x,
            Y: y,
            Z: _layer,
            TileDefId: tile.TileDefId,
            MaterialId: tile.MaterialId,
            TreeSpeciesId: tile.TreeSpeciesId,
            OreId: tile.OreId,
            IsAquifer: tile.IsAquifer,
            IsPassable: tile.IsPassable,
            FluidType: tile.FluidType.ToString(),
            FluidLevel: tile.FluidLevel);
    }

    private void NormalizeInputs()
    {
        _width = Math.Clamp(_width, 16, 128);
        _height = Math.Clamp(_height, 16, 128);
        _depth = Math.Clamp(_depth, 1, 32);
        _worldWidth = Math.Clamp(_worldWidth, 4, 64);
        _worldHeight = Math.Clamp(_worldHeight, 4, 64);
        _regionWidth = Math.Clamp(_regionWidth, 4, 48);
        _regionHeight = Math.Clamp(_regionHeight, 4, 48);
        _worldX = Math.Clamp(_worldX, 0, _worldWidth - 1);
        _worldY = Math.Clamp(_worldY, 0, _worldHeight - 1);
        _regionX = Math.Clamp(_regionX, 0, _regionWidth - 1);
        _regionY = Math.Clamp(_regionY, 0, _regionHeight - 1);
    }

    private void ApplyRequest(MapPreviewRequest request)
    {
        _seed = request.Seed;
        _width = request.LocalWidth;
        _height = request.LocalHeight;
        _depth = request.LocalDepth;
        _worldWidth = request.WorldWidth;
        _worldHeight = request.WorldHeight;
        _regionWidth = request.RegionWidth;
        _regionHeight = request.RegionHeight;
        _worldX = request.WorldX;
        _worldY = request.WorldY;
        _regionX = request.RegionX;
        _regionY = request.RegionY;
    }

    private string GetWorldGridStyle()
    {
        if (_run is null)
            return string.Empty;

        return $"--cell-size: 12px; grid-template-columns: repeat({_run.WorldMap.Width}, var(--cell-size));";
    }

    private string GetRegionGridStyle()
    {
        if (_run is null)
            return string.Empty;

        return $"--cell-size: 12px; grid-template-columns: repeat({_run.RegionMap.Width}, var(--cell-size));";
    }

    private string GetLocalGridStyle()
    {
        if (_run is null)
            return string.Empty;

        return $"--cell-size: {_cellSize}px; grid-template-columns: repeat({_run.LocalMap.Width}, var(--cell-size));";
    }

    private static string GetWorldTileStyle(GeneratedWorldTile tile)
    {
        var style = $"background-color: {GetWorldTileColor(tile.MacroBiomeId)};";
        if (!tile.HasRiver)
            return style;

        return style + BuildRiverOverlayStyle(
            north: WorldRiverEdgeMask.Has(tile.RiverEdges, WorldRiverEdges.North),
            east: WorldRiverEdgeMask.Has(tile.RiverEdges, WorldRiverEdges.East),
            south: WorldRiverEdgeMask.Has(tile.RiverEdges, WorldRiverEdges.South),
            west: WorldRiverEdgeMask.Has(tile.RiverEdges, WorldRiverEdges.West),
            edgeColor: "rgba(56, 189, 248, 0.95)",
            centerColor: "rgba(59, 130, 246, 0.90)");
    }

    private string GetRegionTileStyle(GeneratedRegionTile tile)
    {
        var style = $"background-color: {GetRegionTileColor(tile)};";
        if (!tile.HasRiver)
            return style;

        return style + BuildRiverOverlayStyle(
            north: RegionRiverEdgeMask.Has(tile.RiverEdges, RegionRiverEdges.North),
            east: RegionRiverEdgeMask.Has(tile.RiverEdges, RegionRiverEdges.East),
            south: RegionRiverEdgeMask.Has(tile.RiverEdges, RegionRiverEdges.South),
            west: RegionRiverEdgeMask.Has(tile.RiverEdges, RegionRiverEdges.West),
            edgeColor: "rgba(59, 130, 246, 0.96)",
            centerColor: "rgba(37, 99, 235, 0.92)");
    }

    private static string GetLocalTileStyle(GeneratedTile tile)
    {
        var borderColor = tile.IsPassable ? "rgba(255, 255, 255, 0.08)" : "rgba(15, 23, 42, 0.65)";
        var aquiferOverlay = tile.IsAquifer ? "box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.85);" : string.Empty;
        return $"background-color: {GetLocalTileColor(tile)}; border-color: {borderColor}; {aquiferOverlay}";
    }

    private static string GetWorldTileColor(string macroBiomeId) =>
        macroBiomeId switch
        {
            MacroBiomeIds.ConiferForest => "#2f7d4f",
            MacroBiomeIds.BorealForest => "#355f4a",
            MacroBiomeIds.Highland => "#8c8f9a",
            MacroBiomeIds.MistyMarsh => "#4f7f9b",
            MacroBiomeIds.WindsweptSteppe => "#c0a464",
            MacroBiomeIds.OceanShallow => "#2f5f8c",
            MacroBiomeIds.OceanDeep => "#17365c",
            MacroBiomeIds.Savanna => "#c08a3e",
            MacroBiomeIds.Desert => "#d2b177",
            MacroBiomeIds.Tundra => "#7f8f9a",
            MacroBiomeIds.IcePlains => "#c7d8e8",
            MacroBiomeIds.TropicalRainforest => "#1e7a4f",
            MacroBiomeIds.TemperatePlains => "#7ea55f",
            _ => "#60758a",
        };

    private string GetRegionTileColor(GeneratedRegionTile tile)
    {
        return _regionHeatMode switch
        {
            HeatModeVegetation => ToHeatColor(tile.VegetationDensity, hue: 134),
            HeatModeResources => ToHeatColor(tile.ResourceRichness, hue: 36),
            HeatModeSlope => ToHeatColor(tile.Slope / 255f, hue: 214),
            HeatModeRivers => tile.HasRiver
                ? ToHeatColor(GetRiverEdgeCount(tile.RiverEdges) / 4f, hue: 210)
                : "#27303f",
            _ => GetRegionBiomeColor(tile.BiomeVariantId),
        };
    }

    private static int GetRiverEdgeCount(RegionRiverEdges edges)
    {
        var count = 0;
        if (RegionRiverEdgeMask.Has(edges, RegionRiverEdges.North)) count++;
        if (RegionRiverEdgeMask.Has(edges, RegionRiverEdges.East)) count++;
        if (RegionRiverEdgeMask.Has(edges, RegionRiverEdges.South)) count++;
        if (RegionRiverEdgeMask.Has(edges, RegionRiverEdges.West)) count++;
        return count;
    }

    private static string BuildRiverOverlayStyle(
        bool north,
        bool east,
        bool south,
        bool west,
        string edgeColor,
        string centerColor)
    {
        return
            $" border-top-color: {(north ? edgeColor : "rgba(255, 255, 255, 0.06)")};" +
            $" border-right-color: {(east ? edgeColor : "rgba(255, 255, 255, 0.06)")};" +
            $" border-bottom-color: {(south ? edgeColor : "rgba(255, 255, 255, 0.06)")};" +
            $" border-left-color: {(west ? edgeColor : "rgba(255, 255, 255, 0.06)")};" +
            $" background-image: radial-gradient(circle at center, {centerColor} 0 36%, transparent 37%);";
    }

    private static string GetRegionBiomeColor(string biomeVariantId)
    {
        if (RegionBiomeVariantIds.IsConiferVariant(biomeVariantId))
            return "#2f7d4f";
        if (string.Equals(biomeVariantId, RegionBiomeVariantIds.ForestedFoothills, StringComparison.OrdinalIgnoreCase))
            return "#4a7f4f";
        if (RegionBiomeVariantIds.IsRockyVariant(biomeVariantId) ||
            string.Equals(biomeVariantId, RegionBiomeVariantIds.HighlandFoothills, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(biomeVariantId, RegionBiomeVariantIds.RockyHighland, StringComparison.OrdinalIgnoreCase))
            return "#9ca3af";
        if (RegionBiomeVariantIds.IsMarshVariant(biomeVariantId))
            return "#4d7da6";
        if (string.Equals(biomeVariantId, RegionBiomeVariantIds.BoggyFen, StringComparison.OrdinalIgnoreCase))
            return "#4f7f78";
        if (RegionBiomeVariantIds.IsSteppeVariant(biomeVariantId))
            return "#c4a76e";
        if (string.Equals(biomeVariantId, RegionBiomeVariantIds.SparseSteppe, StringComparison.OrdinalIgnoreCase))
            return "#b89b63";
        if (string.Equals(biomeVariantId, RegionBiomeVariantIds.CoastalShallows, StringComparison.OrdinalIgnoreCase))
            return "#2f5f8c";
        if (string.Equals(biomeVariantId, RegionBiomeVariantIds.OpenOcean, StringComparison.OrdinalIgnoreCase))
            return "#17365c";
        if (string.Equals(biomeVariantId, RegionBiomeVariantIds.RiverValley, StringComparison.OrdinalIgnoreCase))
            return "#5d905d";
        if (string.Equals(biomeVariantId, RegionBiomeVariantIds.MeadowPlain, StringComparison.OrdinalIgnoreCase))
            return "#86b86a";
        if (string.Equals(biomeVariantId, RegionBiomeVariantIds.TemperateWoodland, StringComparison.OrdinalIgnoreCase))
            return "#5e9554";
        return "#7ba65b";
    }

    private static string ToHeatColor(float value, int hue)
    {
        var clamped = Math.Clamp(value, 0f, 1f);
        var saturation = 58 + (int)(clamped * 18);
        var lightness = 18 + (int)(clamped * 50);
        return $"hsl({hue}deg {saturation}% {lightness}%)";
    }

    private static string GetLocalTileColor(GeneratedTile tile) =>
        tile.TileDefId switch
        {
            GeneratedTileDefIds.Tree => "#2f9e44",
            GeneratedTileDefIds.Water => tile.FluidLevel switch
            {
                >= 3 => "#0b5ed7",
                2 => "#3b82f6",
                _ => "#93c5fd",
            },
            GeneratedTileDefIds.Magma => "#e65100",
            GeneratedTileDefIds.GraniteWall => "#6b7280",
            GeneratedTileDefIds.BasaltWall => "#4b5563",
            GeneratedTileDefIds.ShaleWall => "#57534e",
            GeneratedTileDefIds.SlateWall => "#64748b",
            GeneratedTileDefIds.MarbleWall => "#d1d5db",
            GeneratedTileDefIds.LimestoneWall => "#a8a29e",
            GeneratedTileDefIds.SandstoneWall => "#b08968",
            GeneratedTileDefIds.StoneFloor => "#9ca3af",
            GeneratedTileDefIds.Soil => "#8b5e34",
            GeneratedTileDefIds.Staircase => "#f59e0b",
            GeneratedTileDefIds.Empty => "#111827",
            _ => tile.IsPassable ? "#94a3b8" : "#4b5563",
        };

    private static string GetWorldTileTooltip(int x, int y, GeneratedWorldTile tile)
        => $"({x},{y}) {tile.MacroBiomeId} | elev={tile.ElevationBand:0.00} temp={tile.TemperatureBand:0.00} moisture={tile.MoistureBand:0.00} drainage={tile.DrainageBand:0.00} flow={tile.FlowAccumulation:0.0} river={tile.HasRiver}:{tile.RiverEdges}";

    private static string GetRegionTileTooltip(int x, int y, GeneratedRegionTile tile)
        => $"({x},{y}) {tile.BiomeVariantId} | veg={tile.VegetationDensity:0.00} res={tile.ResourceRichness:0.00} slope={(tile.Slope / 255f):0.00} river={tile.HasRiver}:{tile.RiverEdges} lake={tile.HasLake}";

    private string GetLocalTileTooltip(int x, int y, GeneratedTile tile) =>
        $"x={x}, y={y}, z={_layer} | {tile.TileDefId} | material={(tile.MaterialId ?? "none")} | species={(tile.TreeSpeciesId ?? "none")} | ore={(tile.OreId ?? "none")} | aquifer={tile.IsAquifer} | passable={tile.IsPassable} | fluid={tile.FluidType}:{tile.FluidLevel}";

    private static string FormatRatio(int value, int total)
    {
        if (total <= 0)
            return "0.0%";

        return $"{(value * 100f / total):0.0}%";
    }

    private string ResolvedBiomeLabel =>
        string.IsNullOrWhiteSpace(_run?.ResolvedBiomeId) ? "region-derived (no override)" : _run.ResolvedBiomeId!;

    private sealed record SelectedTileInfo(
        int X,
        int Y,
        int Z,
        string TileDefId,
        string? MaterialId,
        string? TreeSpeciesId,
        string? OreId,
        bool IsAquifer,
        bool IsPassable,
        string FluidType,
        byte FluidLevel);
}
