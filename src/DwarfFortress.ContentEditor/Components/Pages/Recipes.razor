@page "/recipes"
@rendermode InteractiveServer
@inject DataService DataSvc

<PageTitle>Recipes</PageTitle>

<h2>Recipes</h2>

@if (_recipes == null)
{
    <p>Loading...</p>
}
else if (_editing != null)
{
    <h5 class="mt-3">@(_editing.Id == "" ? "New Recipe" : $"Editing: {_editing.Id}")</h5>
    <EditForm Model="_editing" OnValidSubmit="SaveRecipe">
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <label class="form-label">ID</label>
                <InputText class="form-control form-control-sm" @bind-Value="_editing.Id" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Display Name</label>
                <InputText class="form-control form-control-sm" @bind-Value="_editing.DisplayName" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Workshop</label>
                <InputSelect class="form-select form-select-sm" @bind-Value="_editing.Workshop">
                    <option value="">(none)</option>
                    @foreach (var b in _buildings)
                    {
                        <option value="@b.Id">@b.DisplayName</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-3">
                <label class="form-label">Labor</label>
                <InputText class="form-control form-control-sm" @bind-Value="_editing.Labor" placeholder="e.g. carpentry" />
            </div>
        </div>

        <div class="row g-2 mb-3">
            <div class="col-md-2">
                <label class="form-label">Work Time</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_editing.WorkTime" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Skill XP</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_editing.SkillXp" />
            </div>
        </div>

        <h6 class="mb-1">Inputs <button type="button" class="btn btn-outline-secondary btn-sm ms-2" @onclick="AddInput">+ Add</button></h6>
        @for (int i = 0; i < _editing.Inputs.Count; i++)
        {
            var idx = i;
            <div class="row g-2 mb-2 align-items-center">
                <div class="col-md-4">
                    <InputText class="form-control form-control-sm" Value="@TagsDisplay(_editing.Inputs[idx].Tags)"
                               ValueChanged="v => _editing.Inputs[idx].Tags = ParseTags(v)"
                               ValueExpression="@(() => TagsDisplay(_editing.Inputs[idx].Tags))"
                               placeholder="tags (comma-separated)" />
                </div>
                <div class="col-md-2">
                    <InputText class="form-control form-control-sm" @bind-Value="_editing.Inputs[idx].ItemId" placeholder="itemId (optional)" />
                </div>
                <div class="col-md-2">
                    <InputText class="form-control form-control-sm" @bind-Value="_editing.Inputs[idx].MaterialId" placeholder="materialId (optional)" />
                </div>
                <div class="col-md-1">
                    <InputNumber class="form-control form-control-sm" @bind-Value="_editing.Inputs[idx].Qty" />
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => _editing.Inputs.RemoveAt(idx)">x</button>
                </div>
            </div>
        }

        <h6 class="mb-1 mt-3">Outputs <button type="button" class="btn btn-outline-secondary btn-sm ms-2" @onclick="AddOutput">+ Add</button></h6>
        @for (int i = 0; i < _editing.Outputs.Count; i++)
        {
            var idx = i;
            <div class="row g-2 mb-2 align-items-center">
                <div class="col-md-3">
                    <InputSelect class="form-select form-select-sm" @bind-Value="_editing.Outputs[idx].ItemId">
                        <option value="">(select item)</option>
                        @foreach (var item in _items)
                        {
                            <option value="@item.Id">@item.DisplayName</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-2">
                    <InputText class="form-control form-control-sm" @bind-Value="_editing.Outputs[idx].FormRole" placeholder="formRole (optional)" />
                </div>
                <div class="col-md-3">
                    <InputText class="form-control form-control-sm" @bind-Value="_editing.Outputs[idx].MaterialFrom" placeholder="materialFrom (optional)" />
                </div>
                <div class="col-md-1">
                    <InputNumber class="form-control form-control-sm" @bind-Value="_editing.Outputs[idx].Qty" />
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => _editing.Outputs.RemoveAt(idx)">x</button>
                </div>
            </div>
        }

        <div class="mt-3">
            <button type="submit" class="btn btn-primary btn-sm me-2">Save</button>
            <button type="button" class="btn btn-secondary btn-sm" @onclick="() => _editing = null">Cancel</button>
        </div>
    </EditForm>
}
else
{
    <div class="mb-3">
        <button class="btn btn-success btn-sm" @onclick="AddNew">+ New Recipe</button>
    </div>

    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Display Name</th>
                <th>Workshop</th>
                <th>Labor</th>
                <th>Outputs</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in _recipes)
            {
                <tr>
                    <td><code>@r.Id</code></td>
                    <td>@r.DisplayName</td>
                    <td><code>@r.Workshop</code></td>
                    <td>@r.Labor</td>
                    <td>@string.Join(", ", r.Outputs.Select(FormatOutputSummary))</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => Edit(r)">Edit</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(r)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(_feedback))
{
    <div class="alert alert-success mt-3">@_feedback</div>
}

@code {
    private List<RecipeModel>? _recipes;
    private List<BuildingModel> _buildings = [];
    private List<ItemModel> _items = [];
    private RecipeModel? _editing;
    private string _feedback = "";

    protected override void OnInitialized()
    {
        _recipes   = DataSvc.LoadRecipes();
        _buildings = DataSvc.LoadBuildings();
        _items     = DataSvc.LoadItems();
    }

    private void AddNew() => _editing = new RecipeModel { Inputs = [new()], Outputs = [new()] };

    private void Edit(RecipeModel r) => _editing = new RecipeModel
    {
        Id = r.Id,
        DisplayName = r.DisplayName,
        Workshop = r.Workshop,
        Labor = r.Labor,
        WorkTime = r.WorkTime,
        SkillXp = r.SkillXp,
        Inputs = r.Inputs.Select(x => new RecipeInput
        {
            Tags = [.. x.Tags],
            Qty = x.Qty,
            ItemId = x.ItemId,
            MaterialId = x.MaterialId,
        }).ToList(),
        Outputs = r.Outputs.Select(x => new RecipeOutput
        {
            ItemId = x.ItemId,
            Qty = x.Qty,
            MaterialFrom = x.MaterialFrom,
            FormRole = x.FormRole,
        }).ToList(),
    };

    private void AddInput() => _editing!.Inputs.Add(new RecipeInput());
    private void AddOutput() => _editing!.Outputs.Add(new RecipeOutput());

    private static string TagsDisplay(List<string> tags) => string.Join(", ", tags);

    private static List<string> ParseTags(string value) =>
        value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private static string FormatOutputSummary(RecipeOutput output)
    {
        var outputId = string.IsNullOrWhiteSpace(output.ItemId)
            ? $"[{output.FormRole}]"
            : output.ItemId;

        if (!string.IsNullOrWhiteSpace(output.MaterialFrom))
            outputId += $" <- {output.MaterialFrom}";

        return $"{output.Qty}x{outputId}";
    }

    private void SaveRecipe()
    {
        var savedId = _editing!.Id;
        var idx = _recipes!.FindIndex(x => x.Id == _editing!.Id);
        if (idx >= 0)
            _recipes[idx] = _editing!;
        else
            _recipes.Add(_editing!);

        DataSvc.SaveRecipes(_recipes);
        _feedback = $"Saved '{savedId}'.";
        _editing = null;
    }

    private void Delete(RecipeModel recipe)
    {
        _recipes!.Remove(recipe);
        DataSvc.SaveRecipes(_recipes);
        _feedback = $"Deleted '{recipe.Id}'.";
    }
}
