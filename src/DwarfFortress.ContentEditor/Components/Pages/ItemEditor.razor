@* Shared sub-component for editing a single ItemModel.
   No @rendermode here — parent page (Items.razor) already owns the interactive circuit. *@

<EditForm Model="Item" OnValidSubmit="HandleSave">
    <DataAnnotationsValidator />
    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <label class="form-label">ID</label>
            <InputText class="form-control form-control-sm" @bind-Value="Item.Id" placeholder="snake_case_id" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Display Name</label>
            <InputText class="form-control form-control-sm" @bind-Value="Item.DisplayName" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Weight</label>
            <InputNumber class="form-control form-control-sm" @bind-Value="Item.Weight" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Base Value</label>
            <InputNumber class="form-control form-control-sm" @bind-Value="Item.BaseValue" />
        </div>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <label class="form-label">Tags (comma-separated)</label>
            <InputText class="form-control form-control-sm" Value="@_tagsText" ValueChanged="OnTagsChanged" ValueExpression="() => _tagsText" />
        </div>
        <div class="col-md-2 d-flex align-items-end gap-2">
            <div class="form-check">
                <InputCheckbox class="form-check-input" @bind-Value="Item.Stackable" id="stackable" />
                <label class="form-check-label" for="stackable">Stackable</label>
            </div>
        </div>
        @if (Item.Stackable)
        {
            <div class="col-md-2">
                <label class="form-label">Max Stack</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="Item.MaxStack" />
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary btn-sm me-2">Save</button>
    <button type="button" class="btn btn-secondary btn-sm" @onclick="OnCancel">Cancel</button>
</EditForm>

@code {
    [Parameter, EditorRequired] public ItemModel Item { get; set; } = default!;
    [Parameter] public EventCallback<ItemModel> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string _tagsText = "";

    protected override void OnParametersSet() =>
        _tagsText = string.Join(", ", Item.Tags);

    private void OnTagsChanged(string value)
    {
        _tagsText = value;
        Item.Tags = value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private async Task HandleSave() => await OnSave.InvokeAsync(Item);
}
