@page "/materials"
@rendermode InteractiveServer
@inject DataService DataSvc

<PageTitle>Materials</PageTitle>

<h2>Materials</h2>

@if (_materials == null)
{
    <p>Loading…</p>
}
else if (_editing != null)
{
    <h5 class="mt-3">@(_editing.Id == "" ? "New Material" : $"Editing: {_editing.Id}")</h5>
    <EditForm Model="_editing" OnValidSubmit="SaveMaterial">
        <div class="row g-2 mb-3">
            <div class="col-md-4">
                <label class="form-label">ID</label>
                <InputText class="form-control form-control-sm" @bind-Value="_editing.Id" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Display Name</label>
                <InputText class="form-control form-control-sm" @bind-Value="_editing.DisplayName" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Hardness</label>
                <InputNumber class="form-control form-control-sm" @bind-Value="_editing.Hardness" />
            </div>
        </div>
        <div class="row g-2 mb-3">
            <div class="col-md-6">
                <label class="form-label">Tags (comma-separated)</label>
                <InputText class="form-control form-control-sm" Value="@_tagsText" ValueChanged="OnTagsChanged" ValueExpression="() => _tagsText" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary btn-sm me-2">Save</button>
        <button type="button" class="btn btn-secondary btn-sm" @onclick="() => _editing = null">Cancel</button>
    </EditForm>
}
else
{
    <div class="mb-3">
        <button class="btn btn-success btn-sm" @onclick="AddNew">+ New Material</button>
    </div>

    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Display Name</th>
                <th>Tags</th>
                <th>Hardness</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var mat in _materials)
            {
                <tr>
                    <td><code>@mat.Id</code></td>
                    <td>@mat.DisplayName</td>
                    <td>@string.Join(", ", mat.Tags)</td>
                    <td>@mat.Hardness</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => Edit(mat)">Edit</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(mat)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(_feedback))
{
    <div class="alert alert-success mt-3">@_feedback</div>
}

@code {
    private List<MaterialModel>? _materials;
    private MaterialModel? _editing;
    private string _tagsText = "";
    private string _feedback = "";

    protected override void OnInitialized() => _materials = DataSvc.LoadMaterials();

    private void AddNew() { _editing = new MaterialModel(); _tagsText = ""; }

    private void Edit(MaterialModel m)
    {
        _editing = new MaterialModel { Id = m.Id, DisplayName = m.DisplayName, Tags = [..m.Tags], Hardness = m.Hardness };
        _tagsText = string.Join(", ", m.Tags);
    }

    private void OnTagsChanged(string value)
    {
        _tagsText = value;
        _editing!.Tags = value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private void SaveMaterial()
    {
        var idx = _materials!.FindIndex(x => x.Id == _editing!.Id);
        if (idx >= 0) _materials![idx] = _editing!;
        else _materials!.Add(_editing!);
        DataSvc.SaveMaterials(_materials!);
        _feedback = $"Saved '{_editing!.Id}'.";
        _editing = null;
    }

    private void Delete(MaterialModel m)
    {
        _materials!.Remove(m);
        DataSvc.SaveMaterials(_materials!);
        _feedback = $"Deleted '{m.Id}'.";
    }
}
