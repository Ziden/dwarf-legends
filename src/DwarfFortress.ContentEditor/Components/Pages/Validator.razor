@page "/validator"
@rendermode InteractiveServer
@inject ValidationService ValidSvc

<PageTitle>Validator</PageTitle>

<h2>Validator</h2>

<p>Runs cross-reference checks across all game data definitions.</p>

<button class="btn btn-primary mb-4" @onclick="Run">▶ Run Validation</button>

@if (_errors != null)
{
    @if (_errors.Count == 0)
    {
        <div class="alert alert-success">✅ No issues found — all data looks clean!</div>
    }
    else
    {
        <div class="alert alert-warning">Found <strong>@_errors.Count</strong> issue(s).</div>
        <table class="table table-sm table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Category</th>
                    <th>Item ID</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in _errors)
                {
                    <tr class="@(e.Message.Contains("Duplicate") ? "table-danger" : "table-warning")">
                        <td><code>@e.Category</code></td>
                        <td><code>@e.ItemId</code></td>
                        <td>@e.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<ValidationError>? _errors;

    private void Run() => _errors = ValidSvc.Validate();
}
