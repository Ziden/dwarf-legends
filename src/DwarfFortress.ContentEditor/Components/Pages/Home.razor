@page "/"

<PageTitle>DF Content Editor</PageTitle>

<h1>Dwarf Fortress Content Editor</h1>

<p>Use the sidebar to browse and edit game data definitions.</p>

<div class="row g-3 mt-2">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">🧱 Items</h5>
                <p class="card-text">Edit item definitions — tags, weight, stack size.</p>
                <a href="items" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">🗺 Tiles</h5>
                <p class="card-text">Edit tile definitions — passability, opacity, minable.</p>
                <a href="tiles" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">⚗ Materials</h5>
                <p class="card-text">Edit material definitions — tags, hardness.</p>
                <a href="materials" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">📜 Recipes</h5>
                <p class="card-text">Edit crafting recipes — inputs, outputs, workshop.</p>
                <a href="recipes" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">🏗 Buildings</h5>
                <p class="card-text">Edit building definitions — footprint, construction inputs.</p>
                <a href="buildings" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">🧭 Map Preview</h5>
                <p class="card-text">Regenerate and inspect embark maps for biome/seed debugging.</p>
                <a href="map-preview" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
</div>
