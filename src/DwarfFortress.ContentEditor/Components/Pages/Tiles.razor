@page "/tiles"
@rendermode InteractiveServer
@inject DataService DataSvc

<PageTitle>Tiles</PageTitle>

<h2>Tiles</h2>

@if (_tiles == null)
{
    <p>Loading…</p>
}
else if (_editing != null)
{
    <h5 class="mt-3">@(_editing.Id == "" ? "New Tile" : $"Editing: {_editing.Id}")</h5>
    <EditForm Model="_editing" OnValidSubmit="SaveTile">
        <div class="row g-2 mb-3">
            <div class="col-md-4">
                <label class="form-label">ID</label>
                <InputText class="form-control form-control-sm" @bind-Value="_editing.Id" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Display Name</label>
                <InputText class="form-control form-control-sm" @bind-Value="_editing.DisplayName" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Tags (comma-separated)</label>
                <InputText class="form-control form-control-sm" Value="@_tagsText" ValueChanged="OnTagsChanged" ValueExpression="() => _tagsText" />
            </div>
        </div>
        <div class="row g-2 mb-3">
            <div class="col-auto">
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="_editing.IsPassable" id="passable" />
                    <label class="form-check-label" for="passable">Passable</label>
                </div>
            </div>
            <div class="col-auto">
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="_editing.IsOpaque" id="opaque" />
                    <label class="form-check-label" for="opaque">Opaque</label>
                </div>
            </div>
            <div class="col-auto">
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="_editing.IsMineable" id="mineable" />
                    <label class="form-check-label" for="mineable">Mineable</label>
                </div>
            </div>
        </div>
        <button type="submit" class="btn btn-primary btn-sm me-2">Save</button>
        <button type="button" class="btn btn-secondary btn-sm" @onclick="() => _editing = null">Cancel</button>
    </EditForm>
}
else
{
    <div class="mb-3">
        <button class="btn btn-success btn-sm" @onclick="AddNew">+ New Tile</button>
    </div>

    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Display Name</th>
                <th>Tags</th>
                <th>Passable</th>
                <th>Opaque</th>
                <th>Mineable</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tile in _tiles)
            {
                <tr>
                    <td><code>@tile.Id</code></td>
                    <td>@tile.DisplayName</td>
                    <td>@string.Join(", ", tile.Tags)</td>
                    <td>@(tile.IsPassable ? "✓" : "")</td>
                    <td>@(tile.IsOpaque ? "✓" : "")</td>
                    <td>@(tile.IsMineable ? "✓" : "")</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => Edit(tile)">Edit</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(tile)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(_feedback))
{
    <div class="alert alert-success mt-3">@_feedback</div>
}

@code {
    private List<TileModel>? _tiles;
    private TileModel? _editing;
    private string _feedback = "";
    private string _tagsText = "";

    protected override void OnInitialized() => _tiles = DataSvc.LoadTiles();

    private void AddNew()
    {
        _editing = new TileModel();
        _tagsText = "";
    }

    private void Edit(TileModel t) => _editing = new TileModel
    {
        Id = t.Id, DisplayName = t.DisplayName,
        Tags = [.. t.Tags],
        IsPassable = t.IsPassable, IsOpaque = t.IsOpaque, IsMineable = t.IsMineable
    };

    private void SaveTile()
    {
        var idx = _tiles!.FindIndex(x => x.Id == _editing!.Id);
        if (idx >= 0) _tiles![idx] = _editing!;
        else _tiles!.Add(_editing!);
        DataSvc.SaveTiles(_tiles!);
        _feedback = $"Saved '{_editing!.Id}'.";
        _editing = null;
        _tagsText = "";
    }

    private void Delete(TileModel t)
    {
        _tiles!.Remove(t);
        DataSvc.SaveTiles(_tiles!);
        _feedback = $"Deleted '{t.Id}'.";
    }

    private void OnTagsChanged(string value)
    {
        _tagsText = value;
        if (_editing is not null)
            _editing.Tags = value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }
}
